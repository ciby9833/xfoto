{
  "name": "xfoto",
  "version": "1.0.0",
  "description": "Photo booth vending machine — scan, shoot, print",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint src --ext .js,.jsx",
    "postinstall": "node scripts/patch-electron-node-gyp.js && electron-rebuild -f",
    "setup": "node scripts/patch-electron-node-gyp.js && electron-rebuild -f"
  },
  "overrides": {
    "node-gyp": "^12.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "@electron/rebuild": "^3.6.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "node-gyp": "^12.0.0",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "build": {
    "appId": "com.xfoto.photobooth",
    "productName": "xfoto",
    "files": [
      "out/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": ["**/*"]
      },
      {
        "from": "vendor",
        "to": "vendor",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "sign": false,
      "signingHashAlgorithms": null
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
