# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/xfoto

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
ADMIN_PASSWORD_HASH=          # bcrypt hash, generate with: node -e "const b=require('bcryptjs');console.log(b.hashSync('yourpassword',10))"

# ── File Storage ──────────────────────────────────────────────────────────────
# Set STORAGE_DRIVER=local for dev (saves to backend/uploads/)
# Set STORAGE_DRIVER=s3 for production (Cloudflare R2 or AWS S3)
STORAGE_DRIVER=local

# S3 / Cloudflare R2 (only needed when STORAGE_DRIVER=s3)
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=xfoto-photos
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev   # public bucket URL for downloads

# ── Payment ───────────────────────────────────────────────────────────────────
# Set PAYMENT_DRIVER=mock for dev, xendit or midtrans for production
PAYMENT_DRIVER=mock
XENDIT_SECRET_KEY=
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false

# ── Download codes ────────────────────────────────────────────────────────────
DOWNLOAD_CODE_TTL_HOURS=24     # how long a download code is valid
